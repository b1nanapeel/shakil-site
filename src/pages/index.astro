---
import { site } from "../data/site";
import { work } from "../data/work";
import { writing } from "../data/writing";
import "../styles/global.css";

const buildDate = new Date().toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

const now = new Date();
const hours = now.getHours();
const greeting =
  hours < 12 ? "Good morning" : hours < 18 ? "Good afternoon" : "Good evening";

const nameLetters = site.name.split("").map((ch, i) => ({
  char: ch,
  isSpace: ch === " ",
  index: i,
}));
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{site.name}</title>
    <meta name="description" content={`${site.name} - personal site`} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" id="favicon" />
    <link rel="preconnect" href="https://fonts.googleapis.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Rounded+Mplus+1c:wght@900&display=swap"
      rel="stylesheet"
    />
    <script is:inline>
      (function () {
        var VALID = ["wash", "brooklyn", "bazaar", "chrome", "brick"];
        var t = localStorage.getItem("theme");
        if (t && VALID.indexOf(t) !== -1) {
          document.documentElement.setAttribute("data-theme", t);
        } else {
          document.documentElement.setAttribute("data-theme", "wash");
        }
      })();
    </script>
  </head>
  <body>
    <div class="theme-switcher">
      <button class="theme-dot" data-dot="wash" aria-label="Wash theme"></button>
      <button class="theme-dot" data-dot="brooklyn" aria-label="Brooklyn theme"></button>
      <button class="theme-dot" data-dot="bazaar" aria-label="Bazaar theme"></button>
      <button class="theme-dot" data-dot="chrome" aria-label="Chrome theme"></button>
      <button class="theme-dot" data-dot="brick" aria-label="Brick theme"></button>
      <button class="auto-toggle playing" aria-label="Auto theme" title="auto theme">&#9654;</button>
    </div>

    <div class="glitch-overlay" aria-hidden="true">
      <div class="glitch-slice glitch-slice-1"></div>
      <div class="glitch-slice glitch-slice-2"></div>
      <div class="glitch-slice glitch-slice-3"></div>
      <div class="bleed-slice"></div>
    </div>

    <div class="chase-overlay" aria-hidden="true" id="chase-overlay"></div>

    <div class="name-block">
      <h1 class="big-name font-bubble" aria-label={site.name} id="jelly-name">
        {nameLetters.map((l) =>
          l.isSpace ? (
            <span class="name-space" aria-hidden="true">&nbsp;</span>
          ) : (
            <span class="name-letter" aria-hidden="true" data-idx={l.index}>{l.char}</span>
          )
        )}
      </h1>
    </div>
    <p class="updated">{greeting}. Updated {buildDate}.</p>

    <p class="bio" set:html={site.bio} />

    <div class="links">
      {site.links.map((link) => (
        <a href={link.url} class="pill">{link.label}</a>
      ))}
    </div>

    <div class="wave-divider" aria-hidden="true"></div>

    <div class="section">
      <div class="section-header">
        <span class="section-number font-bubble">01</span>
        <h2 class="section-title">Notable Work</h2>
      </div>
      <ul class="work-list">
        {work.map((entry) => (
          <li>
            {entry.url ? (
              <a href={entry.url} class="work-name">{entry.name}</a>
            ) : (
              <span class="work-name">{entry.name}</span>
            )}
            <span class="work-date"> ({entry.date})</span>
            <span class="work-desc">{entry.description}</span>
          </li>
        ))}
      </ul>
    </div>

    <div class="wave-divider" aria-hidden="true"></div>

    <div class="section">
      <div class="section-header">
        <span class="section-number font-bubble">02</span>
        <h2 class="section-title">Writing</h2>
      </div>
      <ul class="work-list">
        {writing.map((entry) => (
          <li>
            {entry.url ? (
              <a href={entry.url} class="work-name">{entry.name}</a>
            ) : (
              <span class="work-name">{entry.name}</span>
            )}
            <span class="work-date"> ({entry.date})</span>
            <span class="work-desc">{entry.description}</span>
          </li>
        ))}
      </ul>
    </div>

    <!-- Globe link -->
    <div class="section">
      <a href="/globe" class="section-header" style="text-decoration:none;color:inherit;">
        <span class="section-number font-bubble">03</span>
        <h2 class="section-title">Globe</h2>
      </a>
    </div>

    <footer>
      <div class="critter-ledge" aria-hidden="true">
        <!-- Acrobat: rounded body, domino mask band, ink outlines -->
        <div class="critter critter-a" id="critter-a">
          <svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
            <ellipse cx="20" cy="24" rx="14" ry="13" fill="var(--accent)" stroke="var(--ink)" stroke-width="1.5"/>
            <rect x="8" y="17" width="24" height="7" rx="3.5" fill="var(--ink)"/>
            <ellipse cx="14" cy="20" rx="3" ry="3.5" fill="white"/>
            <ellipse cx="26" cy="20" rx="3" ry="3.5" fill="white"/>
            <circle cx="15" cy="20.5" r="1.8" fill="var(--accent)"/>
            <circle cx="27" cy="20.5" r="1.8" fill="var(--accent)"/>
            <g class="critter-eye" id="eye-a">
              <rect x="9" y="17" width="10" height="0" rx="1" fill="var(--ink)"/>
              <rect x="21" y="17" width="10" height="0" rx="1" fill="var(--ink)"/>
            </g>
          </svg>
        </div>
        <!-- Stretchy: soft round body, stub feet, dot eyes, wide grin -->
        <div class="critter critter-b" id="critter-b">
          <svg viewBox="0 0 38 40" fill="none" xmlns="http://www.w3.org/2000/svg">
            <ellipse cx="19" cy="22" rx="15" ry="14" fill="var(--secondary)"/>
            <ellipse cx="12" cy="35" rx="4" ry="3" fill="var(--secondary)"/>
            <ellipse cx="26" cy="35" rx="4" ry="3" fill="var(--secondary)"/>
            <circle cx="13" cy="18" r="2.5" fill="white"/>
            <circle cx="25" cy="18" r="2.5" fill="white"/>
            <circle cx="13.5" cy="18.5" r="1.5" fill="var(--ink)"/>
            <circle cx="25.5" cy="18.5" r="1.5" fill="var(--ink)"/>
            <path d="M11 26 Q19 33 27 26" fill="none" stroke="var(--ink)" stroke-width="1.5" stroke-linecap="round"/>
            <g class="critter-eye" id="eye-b">
              <rect x="10" y="16" width="8" height="0" rx="1" fill="var(--secondary)"/>
              <rect x="22" y="16" width="8" height="0" rx="1" fill="var(--secondary)"/>
            </g>
          </svg>
        </div>
      </div>
      <a href={`mailto:${site.email}`}>{site.email}</a>
      <span class="footer-hint">press g</span>
    </footer>

    <script is:inline>
      (function () {
        var THEMES = ["wash", "brooklyn", "bazaar", "chrome", "brick"];
        var HOP_INTERVAL = 40000;
        var GLITCH_DURATION = 500;
        var BLEED_MIN = 10000;
        var BLEED_MAX = 14000;
        var BLEED_DURATION_MIN = 200;
        var BLEED_DURATION_MAX = 300;
        var MIN_GAP = 7000;

        var THEME_COLORS = {
          wash:     { bg: "#FFF5F7", accent: "#E86AA6", secondary: "#5BC8C4", ink: "#2E1065" },
          brooklyn: { bg: "#141126", accent: "#FF3E8A", secondary: "#37D0EE", ink: "#F2EDE4" },
          bazaar:   { bg: "#FFF1DC", accent: "#F4772E", secondary: "#E23E7B", ink: "#3B1518" },
          chrome:   { bg: "#EEF1F6", accent: "#E5303E", secondary: "#2E6BFF", ink: "#0A1128" },
          brick:    { bg: "#FFFFFF", accent: "#D01012", secondary: "#FFCF00", ink: "#1A1A1A" }
        };

        var root = document.documentElement;
        var dots = document.querySelectorAll(".theme-dot");
        var autoBtn = document.querySelector(".auto-toggle");
        var glitchOverlay = document.querySelector(".glitch-overlay");
        var bleedSlice = document.querySelector(".bleed-slice");
        var chaseOverlay = document.getElementById("chase-overlay");
        var reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)");
        var favicon = document.getElementById("favicon");

        var current = root.getAttribute("data-theme") || "wash";
        var autoMode = localStorage.getItem("autoTheme") !== "off";
        var hopTimer = null;
        var bleedTimer = null;
        var glitchTimeout = null;
        var lastEventTime = 0;
        var chaseRunning = false;
        var chaseDirection = 1;
        var rolesFlip = false;

        function currentIndex() { return THEMES.indexOf(current); }
        function nextTheme() { return THEMES[(currentIndex() + 1) % THEMES.length]; }
        function randomBetween(a, b) { return a + Math.floor(Math.random() * (b - a)); }

        function setActiveDot(name) {
          dots.forEach(function (d) {
            d.classList.toggle("active", d.getAttribute("data-dot") === name);
          });
        }

        function updateAutoBtn() {
          autoBtn.classList.toggle("playing", autoMode);
          autoBtn.innerHTML = autoMode ? "&#9654;" : "&#9646;&#9646;";
        }

        function userBusy() {
          var sel = window.getSelection();
          if (sel && sel.toString().length > 0) return true;
          var tag = document.activeElement && document.activeElement.tagName;
          if (tag === "INPUT" || tag === "TEXTAREA") return true;
          return false;
        }

        function timeSinceLastEvent() { return Date.now() - lastEventTime; }

        function updateFavicon(accent) {
          var svg = '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100">'
            + '<rect width="100" height="100" rx="12" fill="' + accent + '"/>'
            + '<text x="50" y="68" font-family="sans-serif" font-size="48" font-weight="600" fill="white" text-anchor="middle">SM</text>'
            + '</svg>';
          favicon.href = "data:image/svg+xml," + encodeURIComponent(svg);
        }

        function applyTheme(name) {
          current = name;
          root.setAttribute("data-theme", name);
          localStorage.setItem("theme", name);
          setActiveDot(name);
          updateFavicon(THEME_COLORS[name].accent);
        }

        function playBoing(freqStart, freqEnd, vol) {
          try {
            var ac = new (window.AudioContext || window.webkitAudioContext)();
            var osc = ac.createOscillator();
            var gain = ac.createGain();
            osc.type = "sine";
            osc.frequency.setValueAtTime(freqStart, ac.currentTime);
            osc.frequency.exponentialRampToValueAtTime(freqEnd, ac.currentTime + 0.1);
            gain.gain.setValueAtTime(vol, ac.currentTime);
            gain.gain.exponentialRampToValueAtTime(0.001, ac.currentTime + 0.15);
            osc.connect(gain);
            gain.connect(ac.destination);
            osc.start();
            osc.stop(ac.currentTime + 0.15);
          } catch (e) {}
        }

        /* SVG builders */
        function acrobatSVG(c) {
          return '<svg viewBox="0 0 40 40" width="40" height="40" fill="none">'
            + '<ellipse cx="20" cy="24" rx="14" ry="13" fill="' + c.accent + '" stroke="' + c.ink + '" stroke-width="1.5"/>'
            + '<rect x="8" y="17" width="24" height="7" rx="3.5" fill="' + c.ink + '"/>'
            + '<ellipse cx="14" cy="20" rx="3" ry="3.5" fill="white"/>'
            + '<ellipse cx="26" cy="20" rx="3" ry="3.5" fill="white"/>'
            + '<circle cx="15" cy="20.5" r="1.8" fill="' + c.accent + '"/>'
            + '<circle cx="27" cy="20.5" r="1.8" fill="' + c.accent + '"/>'
            + '</svg>';
        }

        function stretchySVG(c) {
          return '<svg viewBox="0 0 38 40" width="38" height="40" fill="none">'
            + '<ellipse cx="19" cy="22" rx="15" ry="14" fill="' + c.secondary + '"/>'
            + '<ellipse cx="12" cy="35" rx="4" ry="3" fill="' + c.secondary + '"/>'
            + '<ellipse cx="26" cy="35" rx="4" ry="3" fill="' + c.secondary + '"/>'
            + '<circle cx="13" cy="18" r="2.5" fill="white"/>'
            + '<circle cx="25" cy="18" r="2.5" fill="white"/>'
            + '<circle cx="13.5" cy="18.5" r="1.5" fill="' + c.ink + '"/>'
            + '<circle cx="25.5" cy="18.5" r="1.5" fill="' + c.ink + '"/>'
            + '<path d="M11 26 Q19 33 27 26" fill="none" stroke="' + c.ink + '" stroke-width="1.5" stroke-linecap="round"/>'
            + '</svg>';
        }

        /* ---- CRITTER BLINK ---- */
        function blinkCritter(eyeId, fillColor) {
          var g = document.getElementById(eyeId);
          if (!g) return;
          var rects = g.querySelectorAll("rect");
          rects.forEach(function (r) {
            r.setAttribute("height", "8");
            r.setAttribute("fill", fillColor);
          });
          setTimeout(function () {
            rects.forEach(function (r) { r.setAttribute("height", "0"); });
          }, 150);
        }

        function scheduleBlinkA() {
          setTimeout(function () {
            blinkCritter("eye-a", "var(--ink)");
            scheduleBlinkA();
          }, randomBetween(4000, 7000));
        }

        function scheduleBlinkB() {
          setTimeout(function () {
            blinkCritter("eye-b", "var(--secondary)");
            scheduleBlinkB();
          }, randomBetween(4000, 7000));
        }

        scheduleBlinkA();
        scheduleBlinkB();

        /* ---- CHASE ---- */
        function triggerChase() {
          if (chaseRunning || reducedMotion.matches) return;
          chaseRunning = true;

          var duration = randomBetween(2500, 4000);
          var dir = chaseDirection;
          chaseDirection *= -1;
          rolesFlip = !rolesFlip;
          var acrobatChases = rolesFlip;
          var isCatch = Math.random() < 0.25;
          var vw = window.innerWidth;
          var startX = dir > 0 ? -60 : vw + 60;
          var endX = dir > 0 ? vw + 60 : -60;
          var gap = 60 * dir;
          var colors = THEME_COLORS[current];
          var flipBase = dir < 0 ? "scaleX(-1) " : "";

          var fleeEl = document.createElement("div");
          fleeEl.className = "chase-runner";
          var chaseEl = document.createElement("div");
          chaseEl.className = "chase-runner";

          if (acrobatChases) {
            fleeEl.innerHTML = stretchySVG(colors);
            chaseEl.innerHTML = acrobatSVG(colors);
          } else {
            fleeEl.innerHTML = acrobatSVG(colors);
            chaseEl.innerHTML = stretchySVG(colors);
          }

          fleeEl.style.left = startX + "px";
          chaseEl.style.left = (startX - gap) + "px";
          chaseOverlay.appendChild(fleeEl);
          chaseOverlay.appendChild(chaseEl);

          playBoing(300, 600, 0.06);

          /* Dust puffs */
          var dustCount = 0;
          var dustInterval = setInterval(function () {
            if (dustCount >= 3) { clearInterval(dustInterval); return; }
            var puff = document.createElement("div");
            puff.className = "dust-puff";
            var sz = randomBetween(6, 10);
            puff.style.width = sz + "px";
            puff.style.height = sz + "px";
            puff.style.bottom = (30 + randomBetween(0, 15)) + "px";
            puff.style.left = (parseFloat(chaseEl.style.left) - dir * 10) + "px";
            puff.style.background = colors.secondary;
            chaseOverlay.appendChild(puff);
            setTimeout(function () { if (puff.parentNode) puff.remove(); }, 600);
            dustCount++;
          }, duration / 4);

          /* Move scheduling state */
          var acrobatLastMove = -500;
          var stretchyLastMove = -500;
          var acrobatMove = null;
          var stretchyMove = null;
          var ropeEl = null;
          var armEl = null;
          var catchStarted = false;
          var startTime = performance.now();

          function cleanup() {
            fleeEl.remove();
            chaseEl.remove();
            clearInterval(dustInterval);
            if (ropeEl) ropeEl.remove();
            if (armEl) armEl.remove();
            setTimeout(function () { chaseRunning = false; }, 1000);
          }

          function animateChase(now) {
            var elapsed = now - startTime;
            var t = Math.min(elapsed / duration, 1);

            var fleeX = startX + (endX - startX) * t;
            var chaseX = (startX - gap) + ((endX - gap) - (startX - gap)) * t;

            /* Determine which element is which character */
            var aEl = acrobatChases ? chaseEl : fleeEl;
            var sEl = acrobatChases ? fleeEl : chaseEl;
            var aX = acrobatChases ? chaseX : fleeX;
            var sX = acrobatChases ? fleeX : chaseX;

            var hop = 333;
            var phase = (elapsed / hop) * Math.PI * 2;
            var bounce = Math.abs(Math.sin(phase));

            /* ---- ACROBAT PHYSICS ---- */
            var aY = -bounce * 10;
            var aSX = 1 + 0.06 * (1 - bounce);
            var aSY = 1 - 0.06 * (1 - bounce) + 0.12 * bounce;
            var aRot = Math.sin(phase) * 3;

            /* Schedule acrobat move */
            if (!acrobatMove && elapsed - acrobatLastMove > randomBetween(800, 1200) && elapsed > 400 && t < 0.82) {
              var mType = randomBetween(0, 3);
              acrobatMove = { type: mType, start: elapsed, dur: mType === 2 ? 600 : 300 };
              acrobatLastMove = elapsed;
              if (mType === 2) {
                ropeEl = document.createElement("div");
                ropeEl.className = "chase-rope";
                ropeEl.style.background = colors.ink;
                ropeEl.style.height = "200px";
                ropeEl.style.bottom = "60px";
                chaseOverlay.appendChild(ropeEl);
              }
            }

            if (acrobatMove) {
              var mt = elapsed - acrobatMove.start;
              var mp = Math.min(mt / acrobatMove.dur, 1);

              if (acrobatMove.type === 0) {
                /* Front flip */
                aRot = mp * 360;
                aY = -bounce * 10 - Math.sin(mp * Math.PI) * 25;
              } else if (acrobatMove.type === 1) {
                /* Tuck jump */
                aY = -bounce * 10 - Math.sin(mp * Math.PI) * 30;
                aSX = 1 + 0.15 * Math.sin(mp * Math.PI);
                aSY = 1 - 0.1 * Math.sin(mp * Math.PI);
              } else if (acrobatMove.type === 2) {
                /* Rope swing */
                var swingArc = Math.sin(mp * Math.PI);
                aY = -swingArc * 100;
                aRot = Math.sin(mp * Math.PI * 2 - Math.PI / 2) * 25;
                if (ropeEl) {
                  ropeEl.style.left = (aX + 20) + "px";
                  ropeEl.style.opacity = mp < 0.9 ? "1" : String(1 - (mp - 0.9) / 0.1);
                  ropeEl.style.transform = "rotate(" + (-aRot * 0.3) + "deg)";
                }
              }

              if (mp >= 1) {
                acrobatMove = null;
                if (ropeEl) { ropeEl.remove(); ropeEl = null; }
              }
            }

            /* ---- STRETCHY PHYSICS ---- */
            var sPhase = ((elapsed - 80) / hop) * Math.PI * 2;
            var sBounce = Math.abs(Math.sin(sPhase));
            var sY = -sBounce * 10;
            var sSX = 1 + 0.14 * (1 - sBounce);
            var sSY = 1 - 0.14 * (1 - sBounce) + 0.22 * sBounce;
            var sRot = Math.sin(sPhase) * 5;

            /* Schedule stretchy move */
            if (!stretchyMove && elapsed - stretchyLastMove > randomBetween(900, 1400) && elapsed > 400 && t < 0.82) {
              var sType = randomBetween(0, 2);
              stretchyMove = { type: sType, start: elapsed, dur: sType === 0 ? 500 : 400 };
              stretchyLastMove = elapsed;
              if (sType === 0) {
                armEl = document.createElement("div");
                armEl.className = "chase-arm";
                armEl.style.background = colors.secondary;
                armEl.style.bottom = "50px";
                armEl.style.width = "0px";
                chaseOverlay.appendChild(armEl);
              }
            }

            if (stretchyMove) {
              var smt = elapsed - stretchyMove.start;
              var smp = Math.min(smt / stretchyMove.dur, 1);

              if (stretchyMove.type === 0) {
                /* Arm stretch grab */
                var armLen;
                if (smp < 0.35) {
                  armLen = (smp / 0.35) * 120;
                } else if (smp < 0.5) {
                  armLen = 120;
                } else {
                  armLen = 120 * Math.max(0, 1 - (smp - 0.5) / 0.3);
                  sSX = 1 + 0.18 * Math.sin((smp - 0.5) / 0.5 * Math.PI * 2);
                }
                if (armEl) {
                  armEl.style.width = Math.max(0, armLen) + "px";
                  if (acrobatChases) {
                    armEl.style.left = (sX + (dir > 0 ? -armLen - 5 : 30)) + "px";
                  } else {
                    armEl.style.left = (sX + (dir > 0 ? 30 : -armLen - 5)) + "px";
                  }
                }
              } else if (stretchyMove.type === 1) {
                /* Exaggerated leap */
                if (smp < 0.12) {
                  sSX = 1 + 0.35 * (smp / 0.12);
                  sSY = 1 - 0.25 * (smp / 0.12);
                } else if (smp < 0.5) {
                  var upP = (smp - 0.12) / 0.38;
                  sSX = 0.7;
                  sSY = 1.35;
                  sY = -upP * 40;
                } else if (smp < 0.85) {
                  var downP = (smp - 0.5) / 0.35;
                  sSX = 0.7 + 0.3 * downP;
                  sSY = 1.35 - 0.35 * downP;
                  sY = -40 * (1 - downP);
                } else {
                  var landP = (smp - 0.85) / 0.15;
                  sSX = 1.35 - 0.35 * landP;
                  sSY = 0.7 + 0.3 * landP;
                  sY = 0;
                }
              }

              if (smp >= 1) {
                stretchyMove = null;
                if (armEl) { armEl.remove(); armEl = null; }
              }
            }

            /* Apply transforms */
            aEl.style.left = aX + "px";
            aEl.style.transform = flipBase + "translateY(" + aY + "px) scaleX(" + aSX + ") scaleY(" + aSY + ") rotate(" + aRot + "deg)";

            sEl.style.left = sX + "px";
            sEl.style.transform = flipBase + "translateY(" + sY + "px) scaleX(" + sSX + ") scaleY(" + sSY + ") rotate(" + sRot + "deg)";

            /* ---- CATCH VARIANT ---- */
            if (isCatch && t > 0.75 && !catchStarted) {
              catchStarted = true;
              if (armEl) { armEl.remove(); armEl = null; }
              if (ropeEl) { ropeEl.remove(); ropeEl = null; }
              acrobatMove = null;
              stretchyMove = null;

              playBoing(180, 300, 0.05);

              var tumble = document.createElement("div");
              tumble.className = "chase-tumble";
              tumble.innerHTML = acrobatSVG(colors) + stretchySVG(colors);
              var midX = (aX + sX) / 2;
              tumble.style.left = midX + "px";
              chaseOverlay.appendChild(tumble);
              fleeEl.style.display = "none";
              chaseEl.style.display = "none";

              var tumbleStart = performance.now();
              var tumbleDur = 500;
              var tumbleEndX = endX;

              function animateTumble(tnow) {
                var te = tnow - tumbleStart;
                var tp = Math.min(te / tumbleDur, 1);
                var tx = midX + (tumbleEndX - midX) * tp;
                var trot = tp * 720;
                var tsq = 1 + 0.15 * Math.abs(Math.sin(tp * Math.PI * 4));
                tumble.style.left = tx + "px";
                tumble.style.transform = flipBase + "rotate(" + trot + "deg) scaleX(" + (1 / tsq) + ") scaleY(" + tsq + ")";
                if (tp < 1) {
                  requestAnimationFrame(animateTumble);
                } else {
                  tumble.remove();
                  cleanup();
                }
              }
              requestAnimationFrame(animateTumble);
              return;
            }

            if (t < 1) {
              requestAnimationFrame(animateChase);
            } else {
              cleanup();
            }
          }

          requestAnimationFrame(animateChase);
        }

        /* ---- BLEED ---- */
        function performBleed() {
          if (!autoMode || userBusy() || reducedMotion.matches) return;
          if (timeSinceLastEvent() < MIN_GAP) return;
          lastEventTime = Date.now();

          var next = nextTheme();
          var colors = THEME_COLORS[next];
          var height = randomBetween(20, 60);
          var top = randomBetween(10, 80);
          var offset = (Math.random() < 0.5 ? -1 : 1) * randomBetween(3, 6);
          var dur = randomBetween(BLEED_DURATION_MIN, BLEED_DURATION_MAX);

          bleedSlice.style.top = top + "%";
          bleedSlice.style.height = height + "px";
          bleedSlice.style.background = colors.bg;
          bleedSlice.style.borderTop = "2px solid " + colors.accent;
          bleedSlice.style.borderBottom = "2px solid " + colors.accent;
          bleedSlice.style.transform = "translateX(" + offset + "px)";
          bleedSlice.style.opacity = "0";

          void bleedSlice.offsetWidth;
          bleedSlice.style.animation = "none";
          void bleedSlice.offsetWidth;
          bleedSlice.style.animation = "microBleed " + dur + "ms ease forwards";

          root.classList.add("bleeding");
          glitchOverlay.classList.add("active");

          setTimeout(function () {
            glitchOverlay.classList.remove("active");
            root.classList.remove("bleeding");
            bleedSlice.style.animation = "none";
            bleedSlice.style.opacity = "0";
          }, dur + 50);
        }

        function scheduleBleed() {
          if (bleedTimer) clearTimeout(bleedTimer);
          if (!autoMode) return;
          bleedTimer = setTimeout(function () {
            performBleed();
            scheduleBleed();
          }, randomBetween(BLEED_MIN, BLEED_MAX));
        }

        /* ---- HOP ---- */
        function performHop() {
          if (userBusy()) return;
          if (timeSinceLastEvent() < MIN_GAP) return;
          lastEventTime = Date.now();

          var target = nextTheme();
          root.classList.add("hopping");

          if (!reducedMotion.matches) {
            var colors = THEME_COLORS[target];
            var slices = glitchOverlay.querySelectorAll(".glitch-slice");
            for (var i = 0; i < slices.length; i++) slices[i].style.background = colors.bg;
            glitchOverlay.classList.add("active");
          }

          applyTheme(target);

          if (glitchTimeout) clearTimeout(glitchTimeout);
          glitchTimeout = setTimeout(function () {
            root.classList.remove("hopping");
            glitchOverlay.classList.remove("active");
            glitchTimeout = null;
            setTimeout(function () { triggerChase(); }, 300);
          }, GLITCH_DURATION);
        }

        function startAuto() {
          stopAuto();
          hopTimer = setInterval(function () {
            if (autoMode) performHop();
          }, HOP_INTERVAL);
          scheduleBleed();
        }

        function stopAuto() {
          if (hopTimer) { clearInterval(hopTimer); hopTimer = null; }
          if (bleedTimer) { clearTimeout(bleedTimer); bleedTimer = null; }
        }

        dots.forEach(function (dot) {
          dot.addEventListener("click", function () {
            var theme = dot.getAttribute("data-dot");
            if (theme === current) return;
            autoMode = false;
            localStorage.setItem("autoTheme", "off");
            updateAutoBtn();
            stopAuto();

            lastEventTime = Date.now();
            root.classList.add("hopping");
            if (!reducedMotion.matches) {
              var colors = THEME_COLORS[theme];
              var slices = glitchOverlay.querySelectorAll(".glitch-slice");
              for (var i = 0; i < slices.length; i++) slices[i].style.background = colors.bg;
              glitchOverlay.classList.add("active");
            }
            applyTheme(theme);
            if (glitchTimeout) clearTimeout(glitchTimeout);
            glitchTimeout = setTimeout(function () {
              root.classList.remove("hopping");
              glitchOverlay.classList.remove("active");
              glitchTimeout = null;
              setTimeout(function () { triggerChase(); }, 300);
            }, GLITCH_DURATION);
          });
        });

        autoBtn.addEventListener("click", function () {
          autoMode = !autoMode;
          localStorage.setItem("autoTheme", autoMode ? "on" : "off");
          updateAutoBtn();
          if (autoMode) { startAuto(); } else { stopAuto(); }
        });

        /* ---- JELLY NAME ---- */
        var nameEl = document.getElementById("jelly-name");
        var letters = nameEl.querySelectorAll(".name-letter");

        nameEl.addEventListener("mouseover", function (e) {
          if (reducedMotion.matches) return;
          var span = e.target.closest(".name-letter");
          if (!span) return;
          span.classList.remove("jelly");
          void span.offsetWidth;
          span.classList.add("jelly");
          setTimeout(function () { span.classList.remove("jelly"); }, 300);

          var idx = parseInt(span.getAttribute("data-idx"), 10);
          letters.forEach(function (l) {
            var li = parseInt(l.getAttribute("data-idx"), 10);
            if (li === idx - 1 || li === idx + 1) {
              l.classList.remove("jelly-neighbor");
              void l.offsetWidth;
              l.classList.add("jelly-neighbor");
              setTimeout(function () { l.classList.remove("jelly-neighbor"); }, 300);
            }
          });
        });

        /* ---- EASTER EGG ---- */
        document.addEventListener("keydown", function (e) {
          if (e.key === "g" && !e.ctrlKey && !e.metaKey && !e.altKey) {
            var tag = document.activeElement && document.activeElement.tagName;
            if (tag === "INPUT" || tag === "TEXTAREA") return;
            performHop();
          }
        });

        /* ---- INIT ---- */
        setActiveDot(current);
        updateAutoBtn();
        updateFavicon(THEME_COLORS[current].accent);
        if (autoMode) startAuto();
      })();
    </script>
  </body>
</html>
