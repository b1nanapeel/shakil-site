---
import "../styles/global.css";
import { site } from "../data/site";
import { travel } from "../data/travel";
import NavDock from "../components/NavDock.astro";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Globe - {site.name}</title>
    <meta name="description" content={`${site.name} - travel globe`} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Patrick+Hand&family=Permanent+Marker&family=Fredoka:wght@600&family=Space+Grotesk:wght@700&family=Baloo+2:wght@800&family=Rye&family=Caveat:wght@700&family=Bungee&family=Anton&family=Alfa+Slab+One&family=Press+Start+2P&family=Chewy&family=Cinzel:wght@700&family=Rounded+Mplus+1c:wght@900&family=Special+Elite&family=Pixelify+Sans&family=Silkscreen&family=VT323&family=Pacifico&family=Bebas+Neue&family=Orbitron:wght@700&family=Lilita+One&family=Comfortaa:wght@700&family=Playfair+Display:wght@700&family=Share+Tech+Mono&family=Zen+Maru+Gothic:wght@700&family=Philosopher:wght@700&family=Amatic+SC:wght@700&family=Righteous&family=Baloo+Paaji+2:wght@700&display=swap"
      rel="stylesheet"
    />
    <script is:inline>
      (function () {
        var VALID = ["wash","brooklyn","bazaar","chrome","brick","hoedown","meadow","cape","crimson","quest","arcade","floss","arcana","noir","clouds","maze","handheld","soda","cinema","volt","tropic","frost","press","terminal","reverie","ember","grove","mirage","depths"];
        var t = localStorage.getItem("theme");
        if (t && VALID.indexOf(t) !== -1) {
          document.documentElement.setAttribute("data-theme", t);
        } else {
          document.documentElement.setAttribute("data-theme", "noir");
        }
      })();
    </script>
    <style>
      body {
        max-width: none;
        padding: 0;
        margin: 0;
        overflow: hidden;
        height: 100vh;
      }

      #globe-container {
        width: 100vw;
        height: 100vh;
        cursor: grab;
      }

      #globe-container:active { cursor: grabbing; }

      /* Photo card */
      .photo-card {
        position: fixed;
        z-index: 30;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        background: var(--bg);
        border: var(--border-w) solid var(--ink);
        border-radius: var(--radius);
        box-shadow: var(--shadow-x) var(--shadow-y) 0 var(--card-shadow);
        max-width: 360px;
        width: 90vw;
        overflow: hidden;
        opacity: 1;
        transition: opacity 200ms ease;
      }

      .photo-card.hidden {
        opacity: 0;
        pointer-events: none;
      }

      .photo-card img {
        width: 100%;
        height: 200px;
        object-fit: cover;
        display: block;
        background: var(--ink-muted);
      }

      .photo-info {
        padding: 1rem;
      }

      .photo-info strong {
        display: block;
        font-size: 1rem;
        margin-bottom: 0.25rem;
      }

      .photo-info .photo-country {
        font-size: 0.85rem;
        color: var(--ink-muted);
      }

      .photo-info .photo-caption {
        display: block;
        font-size: 0.9rem;
        margin-top: 0.5rem;
        color: var(--ink-muted);
      }

      .photo-close {
        position: absolute;
        top: 0.5rem;
        right: 0.5rem;
        width: 28px;
        height: 28px;
        border-radius: 50%;
        border: none;
        background: var(--ink);
        color: var(--bg);
        font-size: 14px;
        font-weight: 700;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 2;
        -webkit-appearance: none;
        appearance: none;
      }

      .photo-close:hover { opacity: 0.8; }

      /* Mobile bottom sheet */
      @media (max-width: 640px) {
        .photo-card {
          top: auto;
          left: 0;
          right: 0;
          bottom: 0;
          transform: none;
          max-width: none;
          width: 100%;
          border-radius: var(--radius) var(--radius) 0 0;
          border-bottom: none;
        }
      }

    </style>
  </head>
  <body>
    <NavDock current="globe" />

    <div id="globe-container"></div>

    <div class="photo-card hidden" id="photo-card">
      <button class="photo-close" id="photo-close" aria-label="Close">X</button>
      <img id="photo-img" src="" alt="" />
      <div class="photo-info">
        <strong id="photo-place"></strong>
        <span class="photo-country" id="photo-country"></span>
        <span class="photo-caption" id="photo-caption"></span>
      </div>
    </div>

    <script is:inline define:vars={{ travelJSON: JSON.stringify(travel) }}>
      window.__TRAVEL_DATA__ = JSON.parse(travelJSON);
    </script>

    <script>
      import Globe from "globe.gl";
      // @ts-ignore
      import { feature } from "topojson-client";

      const THEME_MAP: Record<string, { bg: string; ink: string; accent: string; globe: string; land: string; dark: boolean }> = {
        wash:     { bg: "#FFF5F7", ink: "#2E1065", accent: "#E86AA6", globe: "#F8F0F4", land: "#c4a0c8", dark: false },
        brooklyn: { bg: "#141126", ink: "#F2EDE4", accent: "#FF3E8A", globe: "#1a1530", land: "#3a3060", dark: true },
        bazaar:   { bg: "#FFF1DC", ink: "#3B1518", accent: "#F4772E", globe: "#F5E8D0", land: "#c49a6c", dark: false },
        chrome:   { bg: "#EEF1F6", ink: "#0A1128", accent: "#E5303E", globe: "#E0E4EC", land: "#8890a0", dark: false },
        brick:    { bg: "#FFFFFF", ink: "#1A1A1A", accent: "#D01012", globe: "#F0F0F0", land: "#999999", dark: false },
        hoedown:  { bg: "#F6EBD9", ink: "#4A2E1A", accent: "#B3402A", globe: "#F0E4D0", land: "#A08060", dark: false },
        meadow:   { bg: "#EDF2E4", ink: "#2E3D2A", accent: "#E0705E", globe: "#E0EAD8", land: "#7A9A6A", dark: false },
        cape:     { bg: "#EAF3FF", ink: "#101D3C", accent: "#E23636", globe: "#DDE8F6", land: "#8090B0", dark: false },
        crimson:  { bg: "#0B0608", ink: "#E8D9DC", accent: "#C1121F", globe: "#150D10", land: "#3A2530", dark: true },
        quest:    { bg: "#EFE6D0", ink: "#25402F", accent: "#E0731D", globe: "#E4DBC4", land: "#8A9A6A", dark: false },
        arcade:   { bg: "#14122B", ink: "#D9F5E5", accent: "#39FF88", globe: "#1A1835", land: "#2A3858", dark: true },
        floss:    { bg: "#FFEFF7", ink: "#5A2A56", accent: "#FF6FB5", globe: "#F8E4F0", land: "#C090B0", dark: false },
        arcana:   { bg: "#1B1230", ink: "#EFE6D2", accent: "#D9A441", globe: "#201838", land: "#3A3058", dark: true },
        noir:     { bg: "#101010", ink: "#E8E8E8", accent: "#FFFFFF", globe: "#181818", land: "#404040", dark: true },
        clouds:   { bg: "#8ED8F8", ink: "#1E5E3A", accent: "#F8D848", globe: "#A0E0F8", land: "#4A9060", dark: false },
        maze:     { bg: "#000000", ink: "#B8C4FF", accent: "#FFE737", globe: "#0A0A18", land: "#2A2A50", dark: true },
        handheld: { bg: "#C4CFA1", ink: "#1F2A1B", accent: "#4A6B3A", globe: "#B8C098", land: "#5A7A4A", dark: false },
        soda:     { bg: "#FFF6E9", ink: "#3A1F14", accent: "#D6382C", globe: "#F8ECD8", land: "#B0886A", dark: false },
        cinema:   { bg: "#0A0A0A", ink: "#EDEDED", accent: "#DA2B35", globe: "#151515", land: "#3A3A3A", dark: true },
        volt:     { bg: "#191233", ink: "#EDEAFF", accent: "#3EE8FF", globe: "#1E1840", land: "#3A3060", dark: true },
        tropic:   { bg: "#FFE8D1", ink: "#31402A", accent: "#E8503A", globe: "#F8DCC0", land: "#7A9060", dark: false },
        frost:    { bg: "#EFF6FB", ink: "#1D3444", accent: "#4A9ED9", globe: "#E4EEF6", land: "#7090A8", dark: false },
        press:    { bg: "#F4F1E8", ink: "#1A1A1A", accent: "#C0392B", globe: "#EAE6D8", land: "#909090", dark: false },
        terminal: { bg: "#060A06", ink: "#C8F5C8", accent: "#39FF14", globe: "#0A120A", land: "#1A3A1A", dark: true },
        reverie:  { bg: "#DCEBF7", ink: "#33475C", accent: "#E8B84B", globe: "#D0E0F0", land: "#8098B0", dark: false },
        ember:    { bg: "#1C0E0C", ink: "#F2E3D0", accent: "#E8501F", globe: "#201210", land: "#4A2A20", dark: true },
        grove:    { bg: "#152418", ink: "#DCE8D8", accent: "#5FBF6E", globe: "#1A2E20", land: "#2A4A2A", dark: true },
        mirage:   { bg: "#1A1038", ink: "#F5E9DD", accent: "#FF5E8A", globe: "#201840", land: "#3A2858", dark: true },
        depths:   { bg: "#0A1626", ink: "#D8EAE6", accent: "#2EE6C8", globe: "#0E1A2E", land: "#1A3040", dark: true },
      };

      const DOT_COLOR = "#E5303E";
      const travelData = (window as any).__TRAVEL_DATA__ as Array<{
        place: string; country: string; lat: number; lng: number; photo: string; caption?: string;
      }>;

      const container = document.getElementById("globe-container")!;
      const card = document.getElementById("photo-card")!;
      const closeBtn = document.getElementById("photo-close")!;
      const photoImg = document.getElementById("photo-img") as HTMLImageElement;
      const photoPlace = document.getElementById("photo-place")!;
      const photoCountry = document.getElementById("photo-country")!;
      const photoCaption = document.getElementById("photo-caption")!;
      const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)");

      function getTheme(): string {
        return document.documentElement.getAttribute("data-theme") || "noir";
      }

      function getColors() {
        return THEME_MAP[getTheme()] || THEME_MAP.noir;
      }

      let globe: any;
      let autoRotate = !reducedMotion.matches;
      let interacting = false;
      let interactTimeout: ReturnType<typeof setTimeout>;

      fetch("https://cdn.jsdelivr.net/npm/world-atlas@2/land-110m.json")
        .then((r) => r.json())
        .then((topology) => {
          const land = feature(topology, topology.objects.land);
          const colors = getColors();

          globe = Globe()(container)
            .backgroundColor("rgba(0,0,0,0)")
            .showGlobe(true)
            .showAtmosphere(true)
            .atmosphereColor(colors.accent)
            .atmosphereAltitude(0.18)
            .polygonsData(land.features)
            .polygonCapColor(() => colors.land)
            .polygonSideColor(() => "rgba(0,0,0,0)")
            .polygonStrokeColor(() => "rgba(0,0,0,0)")
            .pointsData(travelData)
            .pointColor(() => DOT_COLOR)
            .pointAltitude(0.01)
            .pointRadius(0.4)
            .pointLabel((d: any) => d.place)
            .onPointClick((point: any) => {
              openCard(point);
              globe.pointOfView({ lat: point.lat, lng: point.lng, altitude: 1.5 }, 800);
            })
            .width(container.clientWidth)
            .height(container.clientHeight);

          // Set globe body color
          const globeMat = globe.globeMaterial();
          globeMat.color.set(colors.globe);
          globeMat.emissive.set(colors.dark ? colors.globe : "#000000");
          globeMat.emissiveIntensity = colors.dark ? 0.15 : 0;

          // Auto-rotation
          if (autoRotate) {
            globe.controls().autoRotate = true;
            globe.controls().autoRotateSpeed = 0.4;
          }

          // Pause auto-rotate on interaction
          globe.controls().addEventListener("start", () => {
            interacting = true;
            clearTimeout(interactTimeout);
            globe.controls().autoRotate = false;
          });

          globe.controls().addEventListener("end", () => {
            interacting = false;
            if (autoRotate) {
              interactTimeout = setTimeout(() => {
                globe.controls().autoRotate = true;
              }, 3000);
            }
          });

          // Dot pulse via CSS animation on the canvas points
          if (!reducedMotion.matches) {
            setInterval(() => {
              const t = (Math.sin(Date.now() / 1000 * Math.PI) + 1) / 2;
              globe.pointRadius(0.35 + 0.15 * t);
            }, 100);
          }

          // Watch for theme changes
          const observer = new MutationObserver(() => {
            const c = getColors();
            globe.atmosphereColor(c.accent);
            globe.polygonCapColor(() => c.land);
            globeMat.color.set(c.globe);
            globeMat.emissive.set(c.dark ? c.globe : "#000000");
            globeMat.emissiveIntensity = c.dark ? 0.15 : 0;
            globe.backgroundColor("rgba(0,0,0,0)");
          });

          observer.observe(document.documentElement, {
            attributes: true,
            attributeFilter: ["data-theme"],
          });

          // Resize
          window.addEventListener("resize", () => {
            globe.width(container.clientWidth).height(container.clientHeight);
          });
        });

      function openCard(point: any) {
        photoImg.src = point.photo;
        photoImg.alt = point.place;
        photoPlace.textContent = point.place;
        photoCountry.textContent = point.country;
        photoCaption.textContent = point.caption || "";
        photoCaption.style.display = point.caption ? "block" : "none";
        card.classList.remove("hidden");
      }

      function closeCard() {
        card.classList.add("hidden");
      }

      closeBtn.addEventListener("click", closeCard);

      document.addEventListener("click", (e) => {
        if (
          !card.classList.contains("hidden") &&
          !card.contains(e.target as Node) &&
          !(e.target as HTMLElement).closest(".scene-tooltip")
        ) {
          closeCard();
        }
      });

      document.addEventListener("keydown", (e) => {
        if (e.key === "Escape") closeCard();
      });
    </script>
  </body>
</html>
