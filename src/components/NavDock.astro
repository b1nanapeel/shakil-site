---
interface Props {
  current: "home" | "globe";
}

const { current } = Astro.props;
---

<nav class="nav-dock" aria-label="Site navigation">
  <a
    href="/"
    class:list={["nav-dock-link", { active: current === "home" }]}
    aria-current={current === "home" ? "page" : undefined}
    aria-label="Home"
  >
    <svg class="nav-dock-icon" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M4 10.5L12 4L20 10.5V19C20 19.55 19.55 20 19 20H15C14.45 20 14 19.55 14 19V15C14 14.45 13.55 14 13 14H11C10.45 14 10 14.45 10 15V19C10 19.55 9.55 20 9 20H5C4.45 20 4 19.55 4 19V10.5Z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
    <span class="nav-dock-label">HOME</span>
  </a>
  <a
    href="/globe"
    class:list={["nav-dock-link", { active: current === "globe" }]}
    aria-current={current === "globe" ? "page" : undefined}
    aria-label="Globe"
  >
    <svg class="nav-dock-icon" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
      <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.8"/>
      <ellipse cx="12" cy="12" rx="4" ry="9" stroke="currentColor" stroke-width="1.4"/>
      <path d="M3.5 9H20.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
      <path d="M3.5 15H20.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
    </svg>
    <span class="nav-dock-label">GLOBE</span>
  </a>
</nav>

<style>
  .nav-dock {
    position: fixed;
    bottom: 1.25rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 0.25rem;
    align-items: center;
    padding: 0.4rem 0.6rem;
    background: var(--bg);
    border: var(--border-w) solid var(--ink);
    border-radius: 999px;
    box-shadow: var(--shadow-x) var(--shadow-y) 0 var(--card-shadow);
    z-index: 98;
    transition: background 250ms ease, border-color 250ms ease,
      box-shadow 250ms ease;
  }

  .nav-dock-link {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.15rem;
    padding: 0.35rem 0.75rem;
    border-radius: 999px;
    text-decoration: none;
    color: var(--ink);
    opacity: 0.45;
    transition: transform 250ms cubic-bezier(0.34, 1.56, 0.64, 1),
      opacity 200ms ease, background 200ms ease;
  }

  .nav-dock-link:hover {
    opacity: 0.8;
    transform: scale(1.1);
  }

  .nav-dock-link:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
    border-radius: 999px;
  }

  .nav-dock-link.active {
    opacity: 1;
    color: var(--accent);
  }

  .nav-dock-link.active:hover {
    transform: scale(1.05);
  }

  .nav-dock-icon {
    width: 22px;
    height: 22px;
  }

  .nav-dock-link.active .nav-dock-icon {
    width: 26px;
    height: 26px;
  }

  .nav-dock-label {
    font-size: 0.55rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  /* Safe area for iPhone home bar */
  @supports (padding-bottom: env(safe-area-inset-bottom)) {
    .nav-dock {
      bottom: calc(1.25rem + env(safe-area-inset-bottom));
    }
  }

  /* Small screens: icons only */
  @media (max-width: 480px) {
    .nav-dock-label {
      display: none;
    }

    .nav-dock-link {
      padding: 0.3rem 0.6rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .nav-dock-link {
      transition: none;
    }

    .nav-dock-link:hover {
      transform: none;
    }
  }
</style>
