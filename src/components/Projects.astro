---
import { projects } from "../data/projects";
---

{projects.length > 0 && (
<section id="projects" aria-labelledby="projects-heading">
  <div class="container">
    <span class="eyebrow">Projects</span>
    <h2 id="projects-heading">Things I've Built</h2>
    <hr class="hairline" />
    <ul class="project-grid" role="list">
      {projects.map((project) => (
        <li class="project-card fade-in">
          <h3>{project.name}</h3>
          <p class="project-card__blurb">{project.blurb}</p>
          <ul class="project-card__tags" role="list" aria-label="Technologies used">
            {project.tech.map((t) => (
              <li class="tag">{t}</li>
            ))}
          </ul>
          <div class="project-card__links">
            {project.liveUrl && (
              <a href={project.liveUrl} target="_blank" rel="noopener noreferrer">
                Live Site
              </a>
            )}
            {project.githubUrl && (
              <a href={project.githubUrl} target="_blank" rel="noopener noreferrer">
                GitHub
              </a>
            )}
          </div>
        </li>
      ))}
    </ul>
  </div>
</section>
)}

<style>
  .project-grid {
    list-style: none;
    display: grid;
    gap: var(--space-md);
    grid-template-columns: 1fr;
  }

  @media (min-width: 48rem) {
    .project-grid {
      grid-template-columns: repeat(auto-fill, minmax(20rem, 1fr));
    }
  }

  .project-card {
    background-color: var(--surface);
    border: 1px solid var(--purple-deep);
    border-radius: var(--radius);
    padding: var(--space-md);
    display: flex;
    flex-direction: column;
    transition: border-color var(--transition), transform var(--transition);
  }

  .project-card:hover {
    border-color: var(--purple);
    transform: translateY(-2px);
  }

  @media (prefers-reduced-motion: reduce) {
    .project-card:hover {
      transform: none;
    }
  }

  .project-card__blurb {
    margin-top: var(--space-xs);
    flex: 1;
  }

  .project-card__tags {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: var(--space-sm);
  }

  .tag {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    padding: 0.25rem 0.625rem;
    border-radius: 999px;
    background-color: var(--purple-deep);
    color: var(--purple-lift);
  }

  .project-card__links {
    display: flex;
    gap: var(--space-sm);
    margin-top: var(--space-sm);
    padding-top: var(--space-sm);
    border-top: 1px solid var(--purple-deep);
  }

  .project-card__links a {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--gold);
    min-height: 44px;
    display: inline-flex;
    align-items: center;
  }

  .project-card__links a:hover {
    color: var(--gold-bright);
  }
</style>
