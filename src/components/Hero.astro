---
import { site } from "../data/site";
---

<header class="hero">
  <div class="container">
    <span class="eyebrow fade-in">Portfolio</span>
    <h1 class="fade-in">{site.name}</h1>
    <p class="hero__role fade-in">{site.role}</p>
    <p class="hero__bio fade-in">{site.bio}</p>
    <nav class="hero__links fade-in" aria-label="Primary links">
      <a href={site.links.github} target="_blank" rel="noopener noreferrer">GitHub</a>
      <a href={site.links.linkedin} target="_blank" rel="noopener noreferrer">LinkedIn</a>
      {site.email && <a href={`mailto:${site.email}`}>Email</a>}
      <a href={site.links.resume} target="_blank" rel="noopener noreferrer">Resume</a>
    </nav>
  </div>
</header>

<style>
  .hero {
    padding: var(--space-xl) 0 var(--space-lg);
    min-height: 70vh;
    display: flex;
    align-items: center;
  }

  .hero__role {
    font-family: var(--font-heading);
    font-size: clamp(1.25rem, 2vw + 0.5rem, 1.75rem);
    color: var(--gold);
    margin-top: var(--space-xs);
  }

  .hero__bio {
    max-width: 38rem;
    margin-top: var(--space-sm);
    font-size: 1.125rem;
    line-height: 1.8;
  }

  .hero__links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    margin-top: var(--space-md);
  }

  .hero__links a {
    display: inline-flex;
    align-items: center;
    padding: 0.625rem 1.25rem;
    border: 1px solid var(--purple);
    border-radius: var(--radius);
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--purple-lift);
    transition: background-color var(--transition), color var(--transition),
      border-color var(--transition);
    min-height: 44px;
    min-width: 44px;
  }

  .hero__links a:hover {
    background-color: var(--purple);
    color: var(--heading);
    border-color: var(--purple-lift);
  }
</style>
