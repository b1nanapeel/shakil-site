---
import { experience } from "../data/experience";
---

<section id="experience" aria-labelledby="experience-heading">
  <div class="container">
    <span class="eyebrow">Experience</span>
    <h2 id="experience-heading">Where I've Worked</h2>
    <hr class="hairline" />
    <ol class="exp-list" role="list">
      {experience.map((item) => (
        <li class="exp-item fade-in">
          <div class="exp-item__header">
            <h3>{item.role}</h3>
            <span class="exp-item__company">{item.company}</span>
          </div>
          {item.dates && <span class="exp-item__dates">{item.dates}</span>}
          <p class="exp-item__blurb">{item.blurb}</p>
        </li>
      ))}
    </ol>
  </div>
</section>

<style>
  .exp-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .exp-item {
    padding: var(--space-md);
    background-color: var(--surface);
    border-radius: var(--radius);
    border-left: 3px solid var(--gold);
  }

  .exp-item__header {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: var(--space-xs);
  }

  .exp-item__company {
    color: var(--gold);
    font-weight: 500;
  }

  .exp-item__dates {
    display: block;
    font-size: 0.85rem;
    color: var(--purple-lift);
    margin-top: 0.25rem;
  }

  .exp-item__blurb {
    margin-top: var(--space-xs);
    line-height: 1.7;
  }
</style>
